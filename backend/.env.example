PORT=3000

# Set to "production" in deployed environments. This disables the dev-only
# fallback that returns the email verification code in the HTTP response.
NODE_ENV=production

# Comma-separated list of emails that are granted the admin role on registration.
# This is the ONLY way to become an admin — there is no self-service admin signup.
ADMIN_EMAILS=admin@example.com

# Local development: discrete connection settings (used when MYSQL_URL / DATABASE_URL is not set)
DB_HOST=127.0.0.1
DB_PORT=3307
DB_USER=user
DB_PASSWORD=password
DB_NAME=todo_db

# Railway: the MySQL plugin provides this automatically as MYSQL_URL (or DATABASE_URL).
# If set, it takes priority over the DB_* vars above.
# MYSQL_URL=mysql://user:password@host:port/railway

# Comma-separated list of allowed origins for CORS (frontend URL)
CORS_ORIGIN=http://localhost:5173

# Secret used to sign session JWTs. Change this in production.
JWT_SECRET=change-me-to-a-long-random-string

# Web Push (VAPID) keys for browser push notifications.
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Contact address required by the push protocol (mailto: or https: URL).
VAPID_SUBJECT=mailto:admin@example.com

# Gemini API key for AI task/event parsing
GEMINI_API_KEY=

# SendGrid — メール認証コード送信用 (HTTPS Web API経由、SMTPブロック環境でも動作)
# 1. https://sendgrid.com でアカウント作成（無料: 100通/日）
# 2. Settings → API Keys → Create API Key（Mail Send権限のみでOK）
# 3. Settings → Sender Authentication → Single Sender Verification でFromアドレスを認証
# 未設定の場合は認証コードがAPIレスポンスに直接返されるフォールバックモードになります
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxx
SENDGRID_FROM=your-verified-address@example.com
